# PostgreSQL connection string (see claude.md for EAV table name)
# Example (VPN / internal): postgresql://user:pass@192.168.0.252:5496/restapidb
DATABASE_URL=postgresql://user:password@localhost:5432/finance

# Production: comma-separated origins, or * for any (dev only)
# CORS_ORIGINS=https://finance.example.com

# With explicit CORS_ORIGINS, allow *.streamlit.app (regex). Set false to disable.
# CORS_AUTO_STREAMLIT=true

# Optional custom CORS origin regex (overrides auto Streamlit regex)
# CORS_ORIGIN_REGEX=^https://[a-zA-Z0-9._-]+\.streamlit\.app$

# Force demo data even when DATABASE_URL is set (optional)
# DEMO_MODE=false
